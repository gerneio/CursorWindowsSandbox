<Configuration>
  <MemoryInMB>8192</MemoryInMB>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>$PWD\..\share</HostFolder>
      <SandboxFolder>C:\Users\WDAGUtilityAccount\.sandbox</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <MappedFolder>
      <HostFolder>%TEMP%\SandboxPackageCache</HostFolder>
      <SandboxFolder>C:\PackageCache</SandboxFolder>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>C:\Users\WDAGUtilityAccount\.sandbox\SandboxOnStart.bat CURSOR</Command>
  </LogonCommand>
</Configuration>